{
  "type": "Categorization",
  "elements": [
    {
      "type": "Category",
      "label": "Overview & Metadata",
      "elements": [
        {
          "type": "Group",
          "label": "Document identity",
          "elements": [
            {
              "type": "Control",
              "scope": "#/properties/metadata/properties/title",
              "options": { "focus": true }
            },
            {
              "type": "HorizontalLayout",
              "elements": [
                {
                  "type": "Control",
                  "scope": "#/properties/metadata/properties/version"
                },
                {
                  "type": "Control",
                  "scope": "#/properties/metadata/properties/status"
                }
              ]
            },
            {
              "type": "Control",
              "scope": "#/properties/metadata/properties/purpose"
            },
            {
              "type": "Control",
              "scope": "#/properties/metadata/properties/decision_context"
            }
          ]
        },
        {
          "type": "Group",
          "label": "Ownership & timing",
          "elements": [
            {
              "type": "HorizontalLayout",
              "elements": [
                {
                  "type": "Control",
                  "scope": "#/properties/metadata/properties/owner"
                },
                {
                  "type": "Control",
                  "scope": "#/properties/metadata/properties/author"
                }
              ]
            },
            {
              "type": "HorizontalLayout",
              "elements": [
                {
                  "type": "Control",
                  "scope": "#/properties/metadata/properties/effective_date"
                },
                {
                  "type": "Control",
                  "scope": "#/properties/metadata/properties/next_review_date"
                }
              ]
            },
            {
              "type": "Control",
              "scope": "#/properties/metadata/properties/last_updated"
            }
          ]
        },
        {
          "type": "Group",
          "label": "Stakeholders & change log",
          "elements": [
            {
              "type": "Control",
              "scope": "#/properties/metadata/properties/stakeholders"
            },
            {
              "type": "Control",
              "scope": "#/properties/metadata/properties/change_log"
            }
          ]
        },
        {
          "type": "Group",
          "label": "Reading guide",
          "elements": [
            {
              "type": "Control",
              "scope": "#/properties/sections/properties/reading_guide"
            }
          ]
        }
      ]
    },
    {
      "type": "Category",
      "label": "Business Context",
      "elements": [
        {
          "type": "Group",
          "label": "Scope",
          "elements": [
            {
              "type": "Control",
              "scope": "#/properties/sections/properties/scope"
            }
          ]
        },
        {
          "type": "Group",
          "label": "Drivers & Principles",
          "elements": [
            {
              "type": "Control",
              "scope": "#/properties/sections/properties/drivers_and_principles"
            }
          ]
        }
      ]
    },
    {
      "type": "Category",
      "label": "Solution Options",
      "elements": [
        {
          "type": "Control",
          "scope": "#/properties/sections/properties/solution_options"
        }
      ]
    },
    {
      "type": "Category",
      "label": "Quality & Operations",
      "elements": [
        {
          "type": "Group",
          "label": "Quality attributes (NFRs)",
          "elements": [
            {
              "type": "Control",
              "scope": "#/properties/sections/properties/quality_attributes",
              "options": {
                "showSortButtons": true,
                "elementLabelProp": "attribute"
              }
            }
          ]
        },
        {
          "type": "Group",
          "label": "Operational model",
          "elements": [
            {
              "type": "Control",
              "scope": "#/properties/sections/properties/operational_model"
            }
          ]
        },
        {
          "type": "Group",
          "label": "RAID (risks, assumptions, issues, dependencies)",
          "elements": [
            {
              "type": "Control",
              "scope": "#/properties/sections/properties/raid"
            }
          ]
        }
      ]
    },
    {
      "type": "Category",
      "label": "Governance & Glossary",
      "elements": [
        {
          "type": "Group",
          "label": "Governance",
          "elements": [
            {
              "type": "Control",
              "scope": "#/properties/sections/properties/governance"
            },
            {
              "type": "Control",
              "scope": "#/properties/sections/properties/decisions_and_actions"
            }
          ]
        },
        {
          "type": "Group",
          "label": "Glossary",
          "elements": [
            {
              "type": "Control",
              "scope": "#/properties/sections/properties/glossary"
            }
          ]
        }
      ]
    }
  ]
}
